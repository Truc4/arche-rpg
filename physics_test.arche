#import { game fmt }

[8]Player(1);

main :: proc() {
  Player.pos.x = { 80 };
  Player.pos.y = { 240 };
  Player.vel.x = { 0 };
  Player.vel.y = { 0 };

  run game.step;

  fmt.assert(Player.pos.x[0] > 80, "spring pulls the ball toward center\n");
  fmt.assert(Player.pos.x[0] <= 320, "ball does not overshoot the center in one step\n");
  fmt.printf("ok\n");
}
